[
  {
    "id": "insider",
    "name": "Insider",
    "category": "Marketing Automation & Personalization",
    "icon": "https://useinsider.com/favicon.ico",
    "color": "#FF6B35",
    "detectionRules": {
      "scriptPatterns": [
        "useinsider\\.com",
        "ins\\.js",
        "inone\\.js",
        "insider-api\\.com"
      ],
      "jsVariables": [
        "Insider",
        "ins_object",
        "window.Insider"
      ],
      "cookieNames": [
        "insider_token",
        "ins_sid",
        "ins_visitor_id",
        "insider_eu_survey"
      ],
      "domSelectors": [
        "[class*='ins-element']",
        "[id*='ins-root']",
        "[class*='insider-']",
        "ins-inone"
      ],
      "networkHosts": [
        "useinsider.com",
        "insider-api.com",
        "indigitall.com"
      ]
    },
    "features": {
      "Site Search (Eureka)": [
        "[class*='ins-eureka']",
        "[class*='insider-search']",
        "[id*='insider-search']",
        "[class*='ins-search-result']"
      ],
      "Smart Recommender": [
        "[class*='ins-web-smart-recommender']",
        "[class*='ins-sr-api']"
      ],
      "Faceted Search / Filters (ins-facet)": [
        "[class*='ins-facet']",
        "[class*='ins-sidebar-filters']"
      ],
      "Onsite Notification (ins-notification)": [
        "[class*='ins-notification']"
      ],
      "Onsite Widgets (ins-element)": [
        "[class*='ins-element']",
        "[id*='ins-frameless']",
        "[class*='ins-preview-wrapper']"
      ]
    }
  },
